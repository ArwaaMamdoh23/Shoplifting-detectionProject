    "import cv2\n",
    "import os\n",
    "import shutil\n",
    "\n",
    "def convert_to_25_fps(video_path, output_path):\n",
    "    \"\"\"Convert a video to 25 FPS by selecting frames.\"\"\"\n",
    "    # Open the video\n",
    "    cap = cv2.VideoCapture(video_path)\n",
    "    original_fps = cap.get(cv2.CAP_PROP_FPS)\n",
    "    width = int(cap.get(cv2.CAP_PROP_FRAME_WIDTH))\n",
    "    height = int(cap.get(cv2.CAP_PROP_FRAME_HEIGHT))\n",
    "    \n",
    "    # Calculate the frame interval for 25 FPS\n",
    "    frame_interval = original_fps / 25.0\n",
    "    \n",
    "    frames = []\n",
    "    frame_count = 0\n",
    "    while True:\n",
    "        ret, frame = cap.read()\n",
    "        if not ret:\n",
    "            break\n",
    "        if frame_count % round(frame_interval) == 0:\n",
    "            frames.append(frame)\n",
    "        frame_count += 1\n",
    "    cap.release()\n",
    "    \n",
    "    # Initialize video writer for output file\n",
    "    fourcc = cv2.VideoWriter_fourcc(*\"mp4v\")\n",
    "    out = cv2.VideoWriter(output_path, fourcc, 25, (width, height))\n",
    "    \n",
    "    # Write frames\n",
    "    for frame in frames:\n",
    "        out.write(frame)\n",
    "    out.release()\n",
    "\n",
    "def process_folder(input_folder, output_folder):\n",
    "    \"\"\"Process a folder of videos, converting them to 25 FPS if necessary.\"\"\"\n",
    "    if not os.path.exists(output_folder):\n",
    "        os.makedirs(output_folder)\n",
    "    \n",
    "    for file in os.listdir(input_folder):\n",
    "        if file.endswith(\".mp4\"):  # Only process .mp4 files\n",
    "            input_path = os.path.join(input_folder, file)\n",
    "            output_path = os.path.join(output_folder, file)\n",
    "            \n",
    "            cap = cv2.VideoCapture(input_path)\n",
    "            original_fps = cap.get(cv2.CAP_PROP_FPS)\n",
    "            cap.release()\n",
    "            \n",
    "            # Convert the video if it's not already 25 FPS\n",
    "            if abs(original_fps - 25) > 0.01:\n",
    "                convert_to_25_fps(input_path, output_path)\n",
    "            else:\n",
    "                shutil.copy(input_path, output_path)  # Keep original if already 25 FPS\n",
    "\n",
    "# Input and output folder paths\n",
    "input_folder_non_shop = r\"D:\\GitHub\\ShopLifting\\ShopLifting\\Shop DataSet\\non shop lifters\"\n",
    "output_folder_non_shop = r\"D:\\GitHub\\ShopLifting\\non_shop_\"\n",
    "input_folder_shop = r\"D:\\GitHub\\ShopLifting\\ShopLifting\\Shop DataSet\\shop lifters\"\n",
    "output_folder_shop = r\"D:\\GitHub\\ShopLifting\\shop\"\n",
    "\n",
    "# Process the folders\n",
    "process_folder(input_folder_non_shop, output_folder_non_shop)\n",
    "process_folder(input_folder_shop, output_folder_shop)\n"
