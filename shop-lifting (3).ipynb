    "import albumentations as A\n",
    "\n",
    "# Define augmentation pipelines\n",
    "spatial_augmentation = A.Compose([\n",
    "    A.HorizontalFlip(p=1),  # Always flip\n",
    "])\n",
    "\n",
    "color_augmentation = A.Compose([\n",
    "    A.RandomBrightnessContrast(p=1),  # Always change brightness/contrast\n",
    "    A.HueSaturationValue(hue_shift_limit=20, sat_shift_limit=30, val_shift_limit=20, p=1),\n",
    "])\n",
    "\n",
    "# ------------------------------------------------------------\n",
    "\n",
    "# Function to apply augmentation to a single video\n",
    "def augment_video(video_path, output_path, augmentation):\n",
    "    cap = cv2.VideoCapture(video_path)\n",
    "    frames = []\n",
    "    \n",
    "    while cap.isOpened():\n",
    "        ret, frame = cap.read()\n",
    "        if not ret:\n",
    "            break\n",
    "        frames.append(frame)\n",
    "    cap.release()\n",
    "\n",
    "    if not frames:\n",
    "        print(f\"Error: No frames found in '{video_path}'\")\n",
    "        return\n",
    "    \n",
    "    # 🔹 Generate a random seed for reproducibility\n",
    "    seed = random.randint(0, 9999)\n",
    "\n",
    "    augmented_frames = []\n",
    "    for frame in frames:\n",
    "        np.random.seed(seed)  # Ensure same augmentation parameters\n",
    "        transformed = augmentation(image=frame)['image']\n",
    "        augmented_frames.append(transformed)\n",
    "\n",
    "    # Save the augmented video\n",
    "    frame_height, frame_width, _ = augmented_frames[0].shape\n",
    "    fourcc = cv2.VideoWriter_fourcc(*'mp4v')\n",
    "    out = cv2.VideoWriter(output_path, fourcc, 25, (frame_width, frame_height))\n",
    "\n",
    "    for frame in augmented_frames:\n",
    "        out.write(frame)\n",
    "    out.release()\n",
    "\n",
    "# ------------------------------------------------------------\n",
    "\n",
    "# Function to augment dataset\n",
    "def augment_dataset(input_folder, output_folder, augmentations):\n",
    "    for class_name in os.listdir(input_folder):\n",
    "        class_input_folder = os.path.join(input_folder, class_name)\n",
    "        class_output_folder = os.path.join(output_folder, class_name)\n",
    "\n",
    "        if not os.path.isdir(class_input_folder):\n",
    "            continue\n",
    "\n",
    "        os.makedirs(class_output_folder, exist_ok=True)\n",
    "\n",
    "        video_files = [f for f in os.listdir(class_input_folder) if f.endswith('.mp4')]\n",
    "        random.shuffle(video_files)\n",
    "\n",
    "        for video_file in video_files:\n",
    "            video_path = os.path.join(class_input_folder, video_file)\n",
    "            output_path = os.path.join(class_output_folder, video_file)\n",
    "\n",
    "            # Pick one augmentation per video\n",
    "            chosen_augmentation = random.choice(augmentations)  \n",
    "            augment_video(video_path, output_path, chosen_augmentation)\n",
    "\n",
    "# ------------------------------------------------------------\n",
    "\n",
    "# Define input and output folders\n",
    "input_folder = \"/kaggle/working/train data\"\n",
    "output_folder = \"/kaggle/working/augmented train data\"\n",
    "os.makedirs(output_folder, exist_ok=True)\n",
    "\n",
    "# Define augmentations\n",
    "augmentations = [spatial_augmentation, color_augmentation]\n",
    "\n",
    "# Apply augmentations\n",
    "augment_dataset(input_folder, output_folder, augmentations)\n"
   ]
