    "#resize all to 640*640\n",
    "def resize_and_pad(frame, target_size=640):\n",
    "\n",
    "    height, width, _ = frame.shape\n",
    "\n",
    "    # Calculate scaling factor\n",
    "    scale = min(target_size / width, target_size / height)\n",
    "\n",
    "    # Resize the frame\n",
    "    resized_frame = cv2.resize(frame, None, fx=scale, fy=scale)\n",
    "\n",
    "    # Pad the frame to make it square\n",
    "    pad_width = target_size - resized_frame.shape[1]\n",
    "    pad_height = target_size - resized_frame.shape[0]\n",
    "    pad_top = pad_height // 2\n",
    "    pad_bottom = pad_height - pad_top\n",
    "    pad_left = pad_width // 2\n",
    "    pad_right = pad_width - pad_left\n",
    "    padded_frame = cv2.copyMakeBorder(resized_frame, pad_top, pad_bottom, pad_left, pad_right, cv2.BORDER_CONSTANT, value=[0, 0, 0])\n",
    "\n",
    "    return padded_frame\n",
    "\n",
    "def resize_videos(folder_path, output_folder, target_size=640):\n",
    "\n",
    "    if not os.path.exists(output_folder):\n",
    "        os.makedirs(output_folder)\n",
    "\n",
    "    for file in os.listdir(folder_path):\n",
    "        if file.endswith((\".mp4\")):\n",
    "            input_path = os.path.join(folder_path, file)\n",
    "            output_path = os.path.join(output_folder, file)\n",
    "\n",
    "            # Open the video\n",
    "            cap = cv2.VideoCapture(input_path)\n",
    "            fps = cap.get(cv2.CAP_PROP_FPS)\n",
    "\n",
    "            # Initialize video writer\n",
    "            fourcc = cv2.VideoWriter_fourcc(*\"mp4v\")\n",
    "            out = cv2.VideoWriter(output_path, fourcc, fps, (target_size, target_size))\n",
    "\n",
    "            while True:\n",
    "                ret, frame = cap.read()\n",
    "                if not ret:\n",
    "                    break\n",
    "                resized_frame = resize_and_pad(frame, target_size)\n",
    "                out.write(resized_frame)\n",
    "\n",
    "            cap.release()\n",
    "            out.release()\n",
    "\n",
    "input_folder = \"/kaggle/working/unified non shop lifters\"\n",
    "output_folder = \"/kaggle/working/resized non shop lifters\"\n",
    "resize_videos(input_folder, output_folder, target_size=640)\n",
    "#----------------------------------------------------\n",
    "input_folder = \"/kaggle/working/unified shop lifters\"\n",
    "output_folder = \"/kaggle/working/resized shop lifters\"\n",
    "resize_videos(input_folder, output_folder, target_size=640)"
   ]
