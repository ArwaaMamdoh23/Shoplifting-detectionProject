    "#split data\n",
    "# Paths to your video folders\n",
    "class1_folder = \"/kaggle/working/norm non shop lifters\"\n",
    "class2_folder = \"/kaggle/working/norm shop lifters\"\n",
    "\n",
    "# Output folders for training, validation, and testing\n",
    "train_folder = \"/kaggle/working/train data\"\n",
    "val_folder = \"/kaggle/working/valid data\"\n",
    "test_folder = \"/kaggle/working/test data\"\n",
    "\n",
    "# Create output folders if they don't exist\n",
    "os.makedirs(train_folder, exist_ok=True)\n",
    "os.makedirs(val_folder, exist_ok=True)\n",
    "os.makedirs(test_folder, exist_ok=True)\n",
    "\n",
    "# List all videos in both folders\n",
    "class1_videos = [(\"class1\", os.path.join(class1_folder, f)) \n",
    "                 for f in os.listdir(class1_folder) if f.endswith(('.mp4'))]\n",
    "class2_videos = [(\"class2\", os.path.join(class2_folder, f)) \n",
    "                 for f in os.listdir(class2_folder) if f.endswith(('.mp4'))]\n",
    "\n",
    "# Combine videos from both classes\n",
    "all_videos = class1_videos + class2_videos\n",
    "\n",
    "# Shuffle the combined list randomly\n",
    "random.shuffle(all_videos)\n",
    "\n",
    "# Define split ratios\n",
    "train_ratio = 0.75\n",
    "val_ratio = 0.20\n",
    "test_ratio = 0.05\n",
    "\n",
    "# Calculate split indices\n",
    "train_split = int(train_ratio * len(all_videos))\n",
    "val_split = train_split + int(val_ratio * len(all_videos))\n",
    "\n",
    "# Split the combined dataset\n",
    "train_set = all_videos[:train_split]\n",
    "val_set = all_videos[train_split:val_split]\n",
    "test_set = all_videos[val_split:]\n",
    "\n",
    "def move_files(file_list, destination_folder):\n",
    "    for class_label, file in file_list:\n",
    "        class_folder = os.path.join(destination_folder, class_label)\n",
    "        os.makedirs(class_folder, exist_ok=True)  # Create class subfolder if it doesn't exist\n",
    "        dest_file = os.path.join(class_folder, os.path.basename(file))\n",
    "        \n",
    "        # If a file with the same name exists, rename the new file\n",
    "        counter = 1\n",
    "        while os.path.exists(dest_file):\n",
    "            name, ext = os.path.splitext(os.path.basename(file))\n",
    "            dest_file = os.path.join(class_folder, f\"{name}_{counter}{ext}\")\n",
    "            counter += 1\n",
    "        \n",
    "        shutil.move(file, dest_file)  # Move the file\n",
    "        \n",
    "# Move training set\n",
    "move_files(train_set, train_folder)\n",
    "\n",
    "# Move validation set\n",
    "move_files(val_set, val_folder)\n",
    "\n",
    "# Move testing set\n",
    "move_files(test_set, test_folder)"
   ]
