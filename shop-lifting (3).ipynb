    "def extract_frames_uniform(video_path, num_frames):\n",
    "\n",
    "    cap = cv2.VideoCapture(video_path)\n",
    "    total_frames = int(cap.get(cv2.CAP_PROP_FRAME_COUNT))\n",
    "    frames = []\n",
    "\n",
    "    # Calculate the interval to sample frames uniformly\n",
    "    interval = max(total_frames // num_frames, 1)\n",
    "\n",
    "    for i in range(num_frames):\n",
    "        # Calculate the frame index to extract\n",
    "        frame_idx = min(i * interval, total_frames - 1)\n",
    "        \n",
    "        # Set the video capture to the desired frame\n",
    "        cap.set(cv2.CAP_PROP_POS_FRAMES, frame_idx)\n",
    "        \n",
    "        # Read the frame\n",
    "        ret, frame = cap.read()\n",
    "        if ret:\n",
    "            frames.append(frame)\n",
    "    \n",
    "    cap.release()\n",
    "    return frames\n",
    "\n",
    "def save_video(frames, output_path, fps=25):\n",
    "\n",
    "    if not frames:\n",
    "        return\n",
    "\n",
    "    height, width, _ = frames[0].shape\n",
    "    fourcc = cv2.VideoWriter_fourcc(*\"mp4v\")  # Codec for .mp4\n",
    "    out = cv2.VideoWriter(output_path, fourcc, fps, (width, height))\n",
    "\n",
    "    for frame in frames:\n",
    "        out.write(frame)\n",
    "    out.release()\n",
    "\n",
    "def process_folder(input_folder, output_folder, num_frames=75):\n",
    "    \n",
    "    if not os.path.exists(output_folder):\n",
    "        os.makedirs(output_folder)\n",
    "\n",
    "    # Loop through all files in the input folder\n",
    "    for file in os.listdir(input_folder):\n",
    "        if file.endswith((\".mp4\")):  # Add other video formats if needed\n",
    "            input_path = os.path.join(input_folder, file)\n",
    "            output_path = os.path.join(output_folder, file)\n",
    "\n",
    "            # Extract frames\n",
    "            frames = extract_frames_uniform(input_path, num_frames)\n",
    "\n",
    "            # Save the processed video\n",
    "            save_video(frames, output_path)\n",
    "\n",
    "\n",
    "# Paths\n",
    "input_folder_non_shop = \"/kaggle/working/non shop lifters\"  \n",
    "input_folder_shop = \"/kaggle/working/shop lifters\" \n",
    "output_folder_non_shop = \"/kaggle/working/unified non shop lifters\"  \n",
    "output_folder_shop = \"/kaggle/working/unified shop lifters\"  \n",
    "\n",
    "# Process both folders\n",
    "process_folder(input_folder_non_shop, output_folder_non_shop, num_frames=75)\n",
    "process_folder(input_folder_shop, output_folder_shop, num_frames=75)\n",
    "\n",
    "print(\"Processing complete!\")"
   ]
