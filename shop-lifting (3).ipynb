    "import os\n",
    "import hashlib\n",
    "\n",
    "def get_file_hash(file_path):\n",
    "    \"\"\"Compute SHA256 hash of a file.\"\"\"\n",
    "    hasher = hashlib.sha256()\n",
    "    with open(file_path, \"rb\") as f:\n",
    "        while chunk := f.read(8192):  # Read in chunks to handle large files\n",
    "            hasher.update(chunk)\n",
    "    return hasher.hexdigest()\n",
    "\n",
    "def remove_duplicate_videos(folder_path):\n",
    "    \"\"\"Remove duplicate video files based on their content (hash) and size.\"\"\"\n",
    "    seen_files = {}  # Store {hash: (file_path, file_size, creation_time)}\n",
    "    duplicates = []\n",
    "\n",
    "    for file in os.listdir(folder_path):\n",
    "        file_path = os.path.join(folder_path, file)\n",
    "\n",
    "        # Ensure it's a file, not a directory\n",
    "        if os.path.isfile(file_path):\n",
    "            file_size = os.path.getsize(file_path)  # Get file size\n",
    "            file_hash = get_file_hash(file_path)  # Get hash\n",
    "            creation_time = os.path.getctime(file_path)  # Get creation timestamp\n",
    "\n",
    "            # If a file with the same hash exists, mark the newer one for deletion\n",
    "            if file_hash in seen_files:\n",
    "                existing_file, existing_size, existing_time = seen_files[file_hash]\n",
    "\n",
    "                if file_size == existing_size:  # Ensure exact size match\n",
    "                    if creation_time > existing_time:  # Keep the oldest file\n",
    "                        duplicates.append(file_path)\n",
    "                    else:\n",
    "                        duplicates.append(existing_file)\n",
    "                        seen_files[file_hash] = (file_path, file_size, creation_time)  # Update reference\n",
    "            else:\n",
    "                seen_files[file_hash] = (file_path, file_size, creation_time)\n",
    "\n",
    "    # Confirm before deleting\n",
    "    if duplicates:\n",
    "        print(\"Duplicates found:\")\n",
    "        for dup in duplicates:\n",
    "            print(dup)\n",
    "        \n",
    "        confirm = input(\"\\nDo you want to delete these files? (yes/no): \").strip().lower()\n",
    "        if confirm == \"yes\":\n",
    "            for duplicate in duplicates:\n",
    "                os.remove(duplicate)\n",
    "        else:\n",
    "            print(\"Deletion canceled.\")\n",
    "    else:\n",
    "        print(f\"No duplicates found in '{folder_path}'.\")\n",
    "\n",
    "folder_path = r\"D:\\GitHub\\ShopLifting\\non_shop_\"\n",
    "\n",
    "remove_duplicate_videos(folder_path)\n",
    "\n",
    "folder_path = r\"D:\\GitHub\\ShopLifting\\shop\"\n",
    "remove_duplicate_videos(folder_path)\n"
   ]
