    "# Function to copy augmented videos to the original training set\n",
    "def add_augmented_to_original(original_folder, augmented_folder):\n",
    "    # Iterate through each class folder in the augmented folder\n",
    "    for class_name in os.listdir(augmented_folder):\n",
    "        class_augmented_folder = os.path.join(augmented_folder, class_name)\n",
    "        class_original_folder = os.path.join(original_folder, class_name)\n",
    "\n",
    "        # Skip if it's not a directory\n",
    "        if not os.path.isdir(class_augmented_folder):\n",
    "            continue\n",
    "\n",
    "        # Create the class folder in the original folder if it doesn't exist\n",
    "        os.makedirs(class_original_folder, exist_ok=True)\n",
    "\n",
    "        # Copy augmented videos to the original folder\n",
    "        for video_file in os.listdir(class_augmented_folder):\n",
    "            src = os.path.join(class_augmented_folder, video_file)\n",
    "            dst = os.path.join(class_original_folder, video_file)\n",
    "            shutil.copy(src, dst)  # Use shutil.copy to keep the augmented folder intact\n",
    "\n",
    "        print(f\"Added augmented videos for class '{class_name}' to the original training set.\")\n",
    "\n",
    "    print(\"All augmented videos have been added to the original training set.\")\n",
    "\n",
    "# Function to count the total number of videos in the training set\n",
    "def count_videos_in_folder(folder_path):\n",
    "    video_count = 0\n",
    "    for class_name in os.listdir(folder_path):\n",
    "        class_folder = os.path.join(folder_path, class_name)\n",
    "        if os.path.isdir(class_folder):\n",
    "            video_count += len([f for f in os.listdir(class_folder) if f.endswith('.mp4')])\n",
    "    return video_count\n",
    "\n",
    "# Define input and output folders\n",
    "original_folder = \"/kaggle/working/train data\"\n",
    "augmented_folder = \"/kaggle/working/augmented train data\"\n",
    "\n",
    "# Add augmented videos to the original training set\n",
    "add_augmented_to_original(original_folder, augmented_folder)\n",
    "\n",
    "# Count the total number of videos in the combined training set\n",
    "total_videos = count_videos_in_folder(original_folder)\n",
    "print(f\"Total number of videos in the training set after adding augmentation: {total_videos}\")"
   ]
