   "source": [
    "# Function to copy dataset to a writable directory\n",
    "def copy_dataset(src_folder, dest_folder):\n",
    "\n",
    "    if not os.path.exists(dest_folder):\n",
    "        os.makedirs(dest_folder)  # Create the destination folder if it doesn't exist\n",
    "    try:\n",
    "        # Copy the entire directory tree\n",
    "        shutil.copytree(src_folder, dest_folder, dirs_exist_ok=True)\n",
    "        print(f\"Dataset copied from {src_folder} to {dest_folder}\")\n",
    "    except Exception as e:\n",
    "        print(f\"Error copying dataset: {e}\")\n",
    "\n",
    "# Paths to dataset\n",
    "input_folder_non_shop = r\"D:\\GitHub\\ShopLifting\\ShopLifting\\Shop DataSet\\non shop lifters\"\n",
    "input_folder_shop = r\"D:\\GitHub\\ShopLifting\\ShopLifting\\Shop DataSet\\shop lifters\"\n",
    "output_folder_non_shop = r\"D:\\GitHub\\ShopLifting\\non_shop_\"\n",
    "output_folder_shop = r\"D:\\GitHub\\ShopLifting\\shop\"\n",
    "\n",
    "\n",
    "# Copy the datasets\n",
    "copy_dataset(input_folder_non_shop, output_folder_non_shop)\n",
    "copy_dataset(input_folder_shop, output_folder_shop)"
   ]
