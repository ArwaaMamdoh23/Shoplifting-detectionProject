    "import cv2\n",
    "import os\n",
    "import numpy as np\n",
    "\n",
    "# Define the function to normalize a single frame (per channel)\n",
    "def min_max_normalize_frame(frame):\n",
    "    frame = frame.astype('float32')  # Convert to float for division\n",
    "    normalized_frame = np.zeros_like(frame, dtype=np.float32)\n",
    "\n",
    "    for c in range(3):  # Normalize per channel (BGR)\n",
    "        frame_min = frame[..., c].min()\n",
    "        frame_max = frame[..., c].max()\n",
    "        if frame_max != frame_min:  # Avoid division by zero\n",
    "            normalized_frame[..., c] = (frame[..., c] - frame_min) / (frame_max - frame_min)\n",
    "        else:\n",
    "            normalized_frame[..., c] = 0  # If all values are the same, set to 0\n",
    "\n",
    "    return normalized_frame\n",
    "\n",
    "# Define the function to normalize a single video\n",
    "def normalize_video(video_path, output_path):\n",
    "    cap = cv2.VideoCapture(video_path)\n",
    "    frame_width = int(cap.get(cv2.CAP_PROP_FRAME_WIDTH))\n",
    "    frame_height = int(cap.get(cv2.CAP_PROP_FRAME_HEIGHT))\n",
    "    fps = cap.get(cv2.CAP_PROP_FPS)\n",
    "    fourcc = cv2.VideoWriter_fourcc(*'mp4v')\n",
    "    out = cv2.VideoWriter(output_path, fourcc, fps, (frame_width, frame_height))\n",
    "\n",
    "    while cap.isOpened():\n",
    "        ret, frame = cap.read()\n",
    "        if not ret:\n",
    "            break\n",
    "        normalized_frame = min_max_normalize_frame(frame)\n",
    "        normalized_frame_uint8 = (normalized_frame * 255).astype('uint8')  # Convert back to [0, 255] for saving\n",
    "        out.write(normalized_frame_uint8)\n",
    "\n",
    "    cap.release()\n",
    "    out.release()\n",
    "\n",
    "# Define the function to normalize all videos in a folder\n",
    "def normalize_all_videos(input_folder, output_folder):\n",
    "    if not os.path.exists(output_folder):\n",
    "        os.makedirs(output_folder)  # Create output folder if it doesn't exist\n",
    "\n",
    "    video_files = [f for f in os.listdir(input_folder) if f.endswith('.mp4')]\n",
    "\n",
    "    for video_file in video_files:\n",
    "        video_path = os.path.join(input_folder, video_file)\n",
    "        output_path = os.path.join(output_folder, video_file)\n",
    "        normalize_video(video_path, output_path)  # Call the normalize_video function\n",
    "\n",
    "    print(\"All videos normalized and saved.\")\n",
    "\n",
    "# Normalize videos from different folders\n",
    "input_folder = \"/kaggle/working/resized shop lifters\"\n",
    "output_folder = \"/kaggle/working/norm shop lifters\"\n",
    "normalize_all_videos(input_folder, output_folder)\n",
    "\n",
    "input_folder = \"/kaggle/working/resized non shop lifters\"\n",
    "output_folder = \"/kaggle/working/norm non shop lifters\"\n",
    "normalize_all_videos(input_folder, output_folder)\n"
   ]
