    "# Function to count frames in a video\n",
    "def count_frames(video_path):\n",
    "    cap = cv2.VideoCapture(video_path)\n",
    "    if not cap.isOpened():\n",
    "        print(f\"Warning: Could not open video {video_path}. Skipping.\")\n",
    "        return 0\n",
    "    total_frames = int(cap.get(cv2.CAP_PROP_FRAME_COUNT))\n",
    "    cap.release()\n",
    "    return total_frames\n",
    "\n",
    "# Function to analyze a folder of videos\n",
    "def analyze_folder(folder_path):\n",
    "    frame_counts = []\n",
    "    for root, dirs, files in os.walk(folder_path):\n",
    "        for file in files:\n",
    "            if file.endswith((\".mp4\")): \n",
    "                video_path = os.path.join(root, file)\n",
    "                frames = count_frames(video_path)\n",
    "                if frames > 0:\n",
    "                    frame_counts.append(frames)\n",
    "    return frame_counts\n",
    "\n",
    "# Function to calculate statistics\n",
    "def calculate_statistics(frame_counts):\n",
    "    stats = {\n",
    "        \"mean\": np.mean(frame_counts),\n",
    "        \"median\": np.median(frame_counts),\n",
    "        \"mode\": Counter(frame_counts).most_common(1)[0][0],  # Most common value\n",
    "        \"min\": np.min(frame_counts),\n",
    "        \"max\": np.max(frame_counts),\n",
    "    }\n",
    "    return stats\n",
    "\n",
    "# Function to plot distribution\n",
    "def plot_distribution(frame_counts, title):\n",
    "    plt.hist(frame_counts, bins=20, edgecolor=\"black\")\n",
    "    plt.xlabel(\"Number of Frames\")\n",
    "    plt.ylabel(\"Frequency\")\n",
    "    plt.title(title)\n",
    "    plt.show()\n",
    "\n",
    "# Paths to your folders\n",
    "non_shop_lifters_folder = \"/kaggle/working/unified non shop lifters\"\n",
    "shop_lifters_folder = \"/kaggle/working/unified shop lifters\"\n",
    "\n",
    "# Analyze both folders\n",
    "non_shop_lifters_counts = analyze_folder(non_shop_lifters_folder)\n",
    "shop_lifters_counts = analyze_folder(shop_lifters_folder)\n",
    "\n",
    "# Combine frame counts from both folders\n",
    "all_frame_counts = non_shop_lifters_counts + shop_lifters_counts\n",
    "\n",
    "# Calculate statistics for the combined data\n",
    "combined_stats = calculate_statistics(all_frame_counts)\n",
    "\n",
    "# Print combined statistics, each on a new line\n",
    "print(\"Combined Statistics (Non-Shop Lifters + Shop Lifters):\")\n",
    "print(f\"Mean: {combined_stats['mean']}\")\n",
    "print(f\"Median: {combined_stats['median']}\")\n",
    "print(f\"Mode: {combined_stats['mode']}\")\n",
    "print(f\"Min: {combined_stats['min']}\")\n",
    "print(f\"Max: {combined_stats['max']}\")\n",
    "\n",
    "# Plot combined distribution\n",
    "plot_distribution(all_frame_counts, \"Combined Frame Distribution (Non-Shop Lifters + Shop Lifters)\")"
   ]
